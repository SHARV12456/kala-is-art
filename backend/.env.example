# ============================================
# KALA IS ART - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kala_is_art
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_SSL=false

# JWT
JWT_SECRET=your_very_long_random_jwt_secret_key_here_minimum_64_chars
JWT_REFRESH_SECRET=your_very_long_random_refresh_secret_key_here_minimum_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Encryption (for sensitive data) - 32 bytes hex
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here_64_chars

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=Kala Is Art <noreply@kalaisart.com>

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Session / Cookie
COOKIE_SECRET=your_cookie_secret_key
COOKIE_SECURE=false

# OTP
OTP_EXPIRES_MINUTES=10
